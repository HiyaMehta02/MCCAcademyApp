# =============================================================================
# MCCC Academy — client environment variables
# =============================================================================
# Copy to `.env` for local dev. Never commit `.env` (already in .gitignore).
#
# Per environment, point each variable at the matching Supabase project and API:
#   dev     → mccc-dev Supabase + local/LAN Face API (HTTP OK on Android dev builds)
#   staging → mccc-staging Supabase + staging Face API (HTTPS required)
#   prod    → mccc-prod Supabase + production Face API (HTTPS required)
#
# EAS builds: set the same EXPO_PUBLIC_* names via `eas secret:create` per profile
# (development / preview / production). See ENVIRONMENTS.md.
# =============================================================================

# --- Supabase (publishable / anon key only — safe in the app) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Face API (FastAPI) ---
# Full base URL, no trailing slash. Takes precedence over EXPO_PUBLIC_IP_ADDRESS.
# Dev example (same Wi‑Fi as phone): http://192.168.1.50:8000
# Staging/prod example: https://face-api-staging.yourhost.com
EXPO_PUBLIC_API_BASE_URL=

# Legacy fallback: host only; app uses http://<host>:8000 (dev convenience).
EXPO_PUBLIC_IP_ADDRESS=
