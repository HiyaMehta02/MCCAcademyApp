# =============================================================================
# MCCC Academy — Face API (FastAPI) server environment variables
# =============================================================================
# Copy to `server/.env` for local dev. Never commit `.env` (already in .gitignore).
#
# Use the **same Supabase project** as the client `.env` for each environment:
#   dev     → mccc-dev
#   staging → mccc-staging
#   prod    → mccc-prod
#
# On the API host (staging/prod), set these in the platform dashboard or secrets manager.
# See ENVIRONMENTS.md.
# =============================================================================

# --- Supabase ---
# Project URL (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Backend only — must bypass RLS for student_auth / attendance writes:
#   New projects: Secret API key (sb_secret_...)
#   Legacy: service_role JWT (three dot-separated segments)
# Never use the publishable/anon key here. Never ship this key in the mobile app.
SUPABASE_KEY=your-secret-or-service-role-key

# Publishable/anon key — verifies coach/admin JWTs on protected routes (same as client anon key).
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Security / operations ---
# Save each /enroll upload under server/debug_enroll/ (default on for local dev).
# Set 0 or false on staging and production API hosts.
DEBUG_ENROLL_IMAGES=1

# Optional: slower CNN face detector if HOG still misses faces (CPU-heavy).
# FACE_CNN_FALLBACK=0
