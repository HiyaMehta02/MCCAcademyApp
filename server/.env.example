# Supabase project URL (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Backend only — must bypass RLS for student_auth / attendance:
#   - New projects: "Secret" API key (often starts with sb_secret_...)
#   - Legacy: service_role JWT (three dot-separated segments)
# Never use the publishable/anon key here. Never commit a real .env or ship this key in the app.
SUPABASE_KEY=your-secret-or-service-role-key

# Publishable/anon key — used to verify admin JWTs on /admin/* routes (same key as in client/.env).
SUPABASE_ANON_KEY=your-anon-key

# Save each /enroll upload under server/debug_enroll/ (default on). Set 0 or false in production.
# DEBUG_ENROLL_IMAGES=0

# Optional: slower CNN face detector if HOG still misses faces (can be very slow on CPU without GPU).
# FACE_CNN_FALLBACK=1